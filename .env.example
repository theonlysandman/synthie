# =============================================================================
# .env.example — copy to .env and fill in your values
# =============================================================================
# NEVER commit .env to source control.
# The CI/CD workflow reads these as GitHub Actions secrets.
# =============================================================================

# ---------------------------------------------------------------------------
# Foundry project endpoint (output by provision.sh)
# Format: https://<resource-name>.services.ai.azure.com/api/projects/<project-name>
# Used by: create_agent.py (AIProjectClient)
# ---------------------------------------------------------------------------
PROJECT_ENDPOINT=https://your-resource-name.services.ai.azure.com/api/projects/your-project-name

# ---------------------------------------------------------------------------
# Short project name (last segment of PROJECT_ENDPOINT after /projects/)
# Used by: main.py (VoiceLive agent_config)
# ---------------------------------------------------------------------------
PROJECT_NAME=your-project-name

# ---------------------------------------------------------------------------
# Voice Live resource endpoint (output by provision.sh)
# Format: https://<resource-name>.services.ai.azure.com/
# Used by: main.py (VoiceLive connect())
# ---------------------------------------------------------------------------
VOICELIVE_ENDPOINT=https://your-resource-name.services.ai.azure.com/

# ---------------------------------------------------------------------------
# Name of the model deployment created by provision.sh
# Used by: create_agent.py (PromptAgentDefinition model parameter)
# ---------------------------------------------------------------------------
MODEL_DEPLOYMENT_NAME=gpt-4-1

# ---------------------------------------------------------------------------
# Agent name — used to get-or-create the Foundry agent
# Used by: create_agent.py and main.py
# ---------------------------------------------------------------------------
AGENT_NAME=synthie

# ---------------------------------------------------------------------------
# Agent version (optional) — pin to a specific version returned by
# create_agent.py (e.g. "1").  Leave blank to use the latest version.
# Used by: main.py (VoiceLive agent_config)
# ---------------------------------------------------------------------------
AGENT_VERSION=

# ---------------------------------------------------------------------------
# Voice Live API version (pinned — do not change unless upgrading SDK)
# ---------------------------------------------------------------------------
VOICELIVE_API_VERSION=2026-04-10

# ---------------------------------------------------------------------------
# Azure neural voice name for agent output
# See: https://aka.ms/tts-voices
# ---------------------------------------------------------------------------
AZURE_VOICE=en-US-AvaNeural

# ---------------------------------------------------------------------------
# Azure resource / provisioning (used by provision.sh)
# ---------------------------------------------------------------------------
REGION=eastus
RESOURCE_GROUP=rg-synthie

# ---------------------------------------------------------------------------
# Persona file path (optional — relative to repo root)
# When set, create_agent.py appends the persona file content to instructions.
# Leave blank to use instructions.md alone.
# ---------------------------------------------------------------------------
PERSONA_FILE=personas/default.md
